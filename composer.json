{
    "name": "vansbeck07/dir-dot-config",
    "description": "Retrieve configuration from files in configuration directory.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Evans Owusu Ofori",
            "email": "vansbeck07@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "vansbeck07/array-utils": "^0.0.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "vansbeck07/array-utils",
                "version": "0.0.2",
                "source": {
                    "type": "git",
                    "url": "https://github.com/vansbeck07/array-utils.git",
                    "reference": "bb63fabb274751695b2f67f5580f66403e20d998"
                },
                "dist": {
                    "type": "zip",
                    "url": "https://api.github.com/repos/vansbeck07/array-utils/zipball/bb63fabb274751695b2f67f5580f66403e20d998",
                    "reference": "bb63fabb274751695b2f67f5580f66403e20d998"
                },
                "autoload": {
                    "psr-4": {
                        "Vansbeck07\\": "src/"
                    }
                }
            }
        }
    ],
    "config": {
        "optimize-autoloader": true
    },
    "autoload": {
        "psr-4": {
            "Vansbeck07\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}